<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <DisableImplicitNamespaceImports>false</DisableImplicitNamespaceImports>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>ScaleformTools</AssemblyName>
    <RootNamespace>ScaleformTools</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2535.41" />
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>

  <!--
    The React build output (npm run build) lands in ../dist.
    At publish time we copy it next to the exe so the app can run offline.
    During development, DevMode=true in MainWindow.xaml.cs points to localhost:5173.
  -->
  <ItemGroup>
    <None Include="..\dist\**" Link="wwwroot\%(RecursiveDir)%(Filename)%(Extension)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
